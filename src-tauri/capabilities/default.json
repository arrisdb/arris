{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the Arris main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "pty:default",
    "shell:allow-open",
    "dialog:default",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:scope-home-recursive",
    "updater:default",
    "process:default",
    "opener:allow-open-path"
  ]
}
