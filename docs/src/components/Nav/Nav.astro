---
import styles from './Nav.module.css';
import DocsSearch from '../docs/DocsSearch/DocsSearch.astro';
import pkg from '../../../package.json';

interface Props {
  active?: 'docs' | 'download';
  docs?: boolean;
}

const { active, docs = false } = Astro.props;
// Latest release version, kept in lockstep with the app by `make bump`.
const version = pkg.version;
---

<nav class:list={[styles.nav, docs && styles.navDocs]}>
  <div class={styles.container} data-nav-root>
    <!-- Brand -->
    <a href="https://arrisdb.app" class={styles.brand} data-mp-cta="nav-brand">
      <img class={styles.logoMark} src="/brand/arris-logo.png" alt="Arris" width="26" height="26" transition:persist="brand-logo" />
      <span class={styles.brandName}>Arris</span>
    </a>
    <a
      href="https://github.com/arrisdb/arris/releases/latest"
      class={styles.version}
      title={`Latest release: v${version}`}
      target="_blank"
      rel="noopener"
      data-mp-cta="nav-version"
    >v{version}</a>

    {docs ? (
      <>
        <div class={styles.docsCta}>
          <a
            href="https://github.com/arrisdb/arris"
            class={styles.github}
            title="Arris on GitHub"
            aria-label="Arris on GitHub"
            target="_blank"
            rel="noopener"
            data-mp-cta="nav-github"
          >
            <img class={styles.githubIcon} src="/brand/github.png" alt="" width="18" height="18" />
          </a>
          <button id="docs-search-trigger" class={styles.search}>
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class={styles.searchText}>Search the docs&hellip;</span>
            <span class={styles.kbd}>&#8984;K</span>
          </button>

          <!-- Mobile: opens the docs sidebar drawer (wired in DocsLayout) -->
          <button class={styles.menuToggle} aria-label="Open docs navigation" aria-expanded="false" data-docs-nav-toggle>
            <svg class={styles.menuToggleIcon} width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </>
    ) : (
      <>
        <!-- Marketing: hamburger collapses the links into a dropdown -->
        <button class={styles.menuToggle} aria-label="Toggle menu" aria-expanded="false" data-nav-toggle>
          <svg class={styles.menuToggleIcon} width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <div class={styles.menu} data-nav-menu>
          <div class={styles.navLinks}>
            <a href="/" class:list={[styles.link, active === 'docs' && styles.linkActive]} data-mp-cta="nav-docs">Docs</a>
            <a href="/download" class:list={[styles.link, active === 'download' && styles.linkActive]} data-mp-cta="nav-download">Download</a>
          </div>
        </div>
      </>
    )}
  </div>
</nav>

{docs && <DocsSearch />}

<script>
  // Re-bind on every navigation: ClientRouter swaps the nav DOM on each view
  // transition, so listeners bound once on first load would be lost.
  function initNav() {
    const root = document.querySelector('[data-nav-root]');
    const toggle = document.querySelector('[data-nav-toggle]');
    if (!root || !toggle) return;
    toggle.addEventListener('click', () => {
      const open = root.classList.toggle('nav-open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    // Close the menu when a link inside it is followed.
    root.querySelectorAll('[data-nav-menu] a').forEach((link) => {
      link.addEventListener('click', () => {
        root.classList.remove('nav-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }

  document.addEventListener('astro:page-load', initNav);
</script>
